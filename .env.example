# homeMaker Environment Configuration
# Copy to .env and fill in your values: cp .env.example .env

# ============================================
# REQUIRED
# ============================================

# Vault encryption key (64-char hex)
# Generate with: openssl rand -hex 32
HOMEMAKER_VAULT_KEY=

# ============================================
# OPTIONAL - AI
# ============================================

# Anthropic API key (only needed if Claude Code CLI auth is NOT configured)
# ANTHROPIC_API_KEY=sk-ant-...

# ============================================
# SERVER
# ============================================

# Server port (default: 8579)
PORT=8579

# Host to bind to (default: 0.0.0.0)
HOST=0.0.0.0

# Data directory (default: ./data)
DATA_DIR=./data

# Skip login prompt in development
AUTOMAKER_AUTO_LOGIN=true

# ============================================
# OPTIONAL - Server Auth
# ============================================

# API key for authenticating requests
# AUTOMAKER_API_KEY=your-random-string

# ============================================
# OPTIONAL - Weather Widget
# ============================================

# OpenWeatherMap API key (free tier: openweathermap.org)
# OPENWEATHERMAP_API_KEY=your-key

# Home coordinates for weather data
# OPENWEATHERMAP_LAT=37.7749
# OPENWEATHERMAP_LON=-122.4194

# ============================================
# OPTIONAL - Sensor History
# ============================================

# Days of sensor reading history to retain (default: 30)
# SENSOR_HISTORY_RETENTION_DAYS=30

# ============================================
# OPTIONAL - GitHub
# ============================================

# GitHub token for PR operations
# GH_TOKEN=

# ============================================
# OPTIONAL - Discord Integration
# ============================================

# DISCORD_TOKEN=
# DISCORD_GUILD_ID=
