# homeMaker — Environment Variables
# Copy this file to .env.homemaker and fill in the values before starting.
#
# Usage:
#   cp .env.homemaker.example .env.homemaker
#   docker compose -f docker-compose.homemaker.yml --env-file .env.homemaker up -d

# ─── Required ─────────────────────────────────────────────────────────────────

# Anthropic API key for AI agents (get from console.anthropic.com)
ANTHROPIC_API_KEY=

# Vault encryption key — 64-char hex string (AES-256-GCM)
# Generate with: openssl rand -hex 32
HOMEMAKER_VAULT_KEY=

# API key for server authentication (any strong random string)
# Generate with: openssl rand -hex 32
AUTOMAKER_API_KEY=

# Tailscale auth key (get from admin.tailscale.com → Settings → Keys)
# Use a reusable auth key tagged with "tag:homemaker"
TS_AUTHKEY=

# ─── Tailscale ────────────────────────────────────────────────────────────────

# Hostname this machine will appear as on your Tailscale network
# Access homeMaker at http://<TAILSCALE_HOSTNAME>:3007 from any TS device
TAILSCALE_HOSTNAME=homemaker

# ─── Optional ─────────────────────────────────────────────────────────────────

# Weather widget (openweathermap.org — free tier is sufficient)
OPENWEATHERMAP_API_KEY=
OPENWEATHERMAP_LAT=
OPENWEATHERMAP_LON=

# Days of sensor reading history to retain (default: 30)
SENSOR_HISTORY_RETENTION_DAYS=30
