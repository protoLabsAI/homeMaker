{
  "name": "automaker",
  "description": "Automaker - AI Development Studio. Manage Kanban boards, AI agents, and feature orchestration.",
  "version": "1.0.2",
  "author": {
    "name": "Proto Labs AI"
  },
  "repository": "https://github.com/proto-labs-ai/automaker",
  "mcpServers": {
    "automaker": {
      "command": "node",
      "args": ["/Users/kj/dev/automaker/packages/mcp-server/dist/index.js"],
      "env": {
        "AUTOMAKER_API_URL": "http://localhost:3008",
        "AUTOMAKER_API_KEY": "automaker-dev-key-2026"
      }
    },
    "discord": {
      "command": "npx",
      "args": ["-y", "mcp-discord"],
      "env": {
        "DISCORD_BOT_TOKEN": "${DISCORD_BOT_TOKEN}"
      }
    },
    "linear": {
      "command": "npx",
      "args": ["-y", "mcp-linear"],
      "env": {
        "LINEAR_API_KEY": "${LINEAR_API_KEY}"
      }
    }
  }
}
